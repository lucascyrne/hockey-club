    "leva": "^0.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.175.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/howler": "^2.2.13",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.175.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "r3f-perf": "^7.2.1",
    "tsx": "^4.20.3",
